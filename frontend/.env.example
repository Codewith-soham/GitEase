# Server-only: used by next.config.mjs to proxy /api/* to the backend.
# Not exposed to the browser — the frontend only ever calls its own /api/*.
BACKEND_URL=http://localhost:5000

# Microsoft Clarity project ID (clarity.microsoft.com). Only loads in
# production; leave unset to disable session-replay/heatmap tracking.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Points at the local agent process on the user's own machine.
# Leave unset in deployed environments (Vercel) - it must stay 127.0.0.1.
NEXT_PUBLIC_AGENT_LOOPBACK_URL=

# Download link for the local agent zip, offered from the topbar and the
# Agent docs page. Leave unset to use the GitHub Releases default.
NEXT_PUBLIC_AGENT_DOWNLOAD_URL=
